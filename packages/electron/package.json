{
  "name": "@maestro/electron",
  "version": "1.0.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron dist/main.js",
    "build": "tsc",
    "start": "electron dist/main.js",
    "gen-icons": "node scripts/gen-icons.cjs",
    "pack": "electron-builder --mac",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.4",
    "@types/node": "^22.0.0"
  },
  "build": {
    "appId": "io.github.tangshuai89.maestro",
    "productName": "Maestro",
    "mac": {
      "category": "public.app-category.music",
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../renderer/dist",
        "to": "renderer"
      },
      {
        "from": "../server/dist",
        "to": "server"
      },
      {
        "from": "build",
        "to": "build"
      }
    ]
  }
}
