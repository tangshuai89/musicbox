# Server
PORT=3200
RENDERER_BASE=http://127.0.0.1:5173
RENDERER_ORIGINS=http://127.0.0.1:5173,http://localhost:3000
SESSION_SECRET=dev-only-secret-change-me
STORAGE_DIR=.storage

# QQ 音乐：走桌面端内嵌登录窗口捕获 cookie，无需 appid/secret/回调地址。
# （旧的 QQ 互联 OAuth 方案已废弃：access_token ≠ qqmusic_key，且网站应用需备案）

# 网易云（可选 dev 模式注入）
# NETEASE_MUSIC_U=

# QR 轮询间隔
NETEASE_QR_POLL_MS=1500

# AI 推荐（可选）：DeepSeek Key，自带，仅本地使用，不上传任何服务器
# DEEPSEEK_API_KEY=

# Spotify OAuth PKCE（可选）：从 https://developer.spotify.com/dashboard
# 申请的 client_id（无需 secret）。存到 .storage 后 process.env 会同步
# SPOTIFY_CLIENT_ID=